class MyQueue {
public:
    stack<int> s1;
    stack<int> s2;
    MyQueue() {}
    void push(int x) { s1.push(x); }
    int pop() {
        if (!s1.empty()) {
            int ans;
            int n1 = s1.size();
            for (int i = 1; i < n1; i++) {
                s2.push(s1.top());
                s1.pop();
            }
            if (s1.size() == 1) {

                ans = s1.top();
                s1.pop();
            }
            int n2 = s2.size();
            for (int i = 1; i <= n2; i++) {
                s1.push(s2.top());
                s2.pop();
            }
            return ans;
        }
        return -1;
    }

    int peek() {
        if (!s1.empty()) {
            int ans;
            int n1 = s1.size();
            for (int i = 1; i < n1; i++) {
                s2.push(s1.top());
                s1.pop();
            }
            if (s1.size() == 1) {
                ans = s1.top();
            }
            int n2 = s2.size();
            for (int i = 1; i <= n2; i++) {
                s1.push(s2.top());
                s2.pop();
            }
            return ans;
        }
        return -1;
    }

    bool empty() { return s1.empty(); }
};

