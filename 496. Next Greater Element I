class Solution {
public:
    vector<int> nextGreaterElement(vector<int>& nums1, vector<int>& nums2) {
        vector<int> ans;
        for (int i = 0; i < nums1.size(); i++) {
            for (int j = 0; j < nums2.size(); j++) {
                if (nums1[i] == nums2[j]) {
                    if(j==nums2.size()-1){
                        ans.push_back(-1);
                        break;
                    }else{
                        int greater = -1;
                        for(int z=j+1;z<nums2.size();z++){
                            if(nums2[j]<nums2[z]){
                                greater = nums2[z];
                                ans.push_back(nums2[z]);
                                break;
                            }
                        }
                        if(greater==-1){
                            ans.push_back(-1);
                            break;
                        }
                        break;
                    }
                }
            }
        }
        return ans;
    }
};
