class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        int start = 0;
        int maxi = 0;
        unordered_map<char,int> freq;
        for(int i=0;i<s.length();i++){
            freq[s[i]]++;
            while(freq[s[i]]>1){
                freq[s[start]]--;
                start++;

            }
            int count = (i-start+1);
            maxi = max(count,maxi);
            
        }
        return maxi;
    }
};
